# Copy this file to .env.local and fill in real values.

# --- PostHog (analytics) ---
# Project API key from PostHog → Project Settings. Starts with "phc_".
NEXT_PUBLIC_POSTHOG_KEY=
# Defaults to https://eu.i.posthog.com if unset. Use https://us.i.posthog.com for US-hosted.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Supabase (waitlist storage) ---
# Project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=
# Service role key (NEVER expose to the client — server-only).
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
# Used in SEO/OG tags. Set to your production URL before deploy.
NEXT_PUBLIC_SITE_URL=https://auruby.app
